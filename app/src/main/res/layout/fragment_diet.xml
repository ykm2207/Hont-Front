<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:fitsSystemWindows="true"
        app:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_scrollFlags="scroll|snap">

            <!-- 날짜 이동 헤더 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="4dp">

                <ImageButton
                    android:id="@+id/btn_prev_day"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_chevron_left"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="이전 날" />

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <ImageButton
                    android:id="@+id/btn_next_day"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_chevron_right"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="다음 날" />
            </LinearLayout>

            <!-- 영양 요약 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp">

                <!-- 칼로리 요약 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/tv_calories_current"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:text="0" />

                    <TextView
                        android:id="@+id/tv_calories_goal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:paddingStart="6dp"
                        android:text="/ 2,000 kcal" />

                    <TextView
                        android:id="@+id/tv_calories_remain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <!-- 탄수화물 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="탄수화물"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_carbs"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="8dp"
                        app:trackCornerRadius="4dp"
                        app:indicatorColor="#FF9800"
                        app:trackColor="#FFE0B2" />

                    <TextView
                        android:id="@+id/tv_carbs"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end" />
                </LinearLayout>

                <!-- 단백질 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="단백질"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_protein"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="8dp"
                        app:trackCornerRadius="4dp"
                        app:indicatorColor="#4CAF50"
                        app:trackColor="#C8E6C9" />

                    <TextView
                        android:id="@+id/tv_protein"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end" />
                </LinearLayout>

                <!-- 지방 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="지방"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_fat"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="8dp"
                        app:trackCornerRadius="4dp"
                        app:indicatorColor="#F44336"
                        app:trackColor="#FFCDD2" />

                    <TextView
                        android:id="@+id/tv_fat"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_diet_log"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
