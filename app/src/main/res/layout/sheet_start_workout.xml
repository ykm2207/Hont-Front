<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- 핸들바 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@color/divider" />

    <!-- 제목 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:text="운동 시작"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <!-- 오늘의 루틴 섹션 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:text="오늘의 루틴"
        android:textSize="13sp"
        android:textColor="@color/text_secondary" />

    <!-- 오늘 루틴 카드 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_today_routine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/primary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_today_routine_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_today_routine_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#CCffffff"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/shape_play_btn"
                android:padding="10dp"
                android:contentDescription="시작" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 오늘 루틴 없을 때 -->
    <LinearLayout
        android:id="@+id/ll_no_today_routine"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/shape_dashed_border"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘 예정된 루틴이 없어요"
            android:textColor="@color/text_disabled"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 내 루틴 + 루틴 만들기 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="내 루틴"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_routine"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="+ 루틴 만들기"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/primary" />
    </LinearLayout>

    <!-- 루틴 없을 때 -->
    <TextView
        android:id="@+id/tv_no_routines"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="아직 저장된 루틴이 없어요"
        android:textColor="@color/text_disabled"
        android:textSize="13sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_routines"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:nestedScrollingEnabled="false" />

    <!-- 자유 운동 시작 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_free_workout"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="32dp"
        android:text="루틴 없이 자유 운동"
        android:textColor="@color/primary" />

</LinearLayout>
