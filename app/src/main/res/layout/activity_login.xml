<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 상단 1/3 - 앱 타이틀 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HONT"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="당신만의 홈 트레이너"
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- 하단 2/3 - 로그인 버튼들 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="bottom|center_horizontal"
        android:paddingHorizontal="32dp"
        android:paddingBottom="52dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_google_login"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Google로 계속하기"
            android:textColor="@color/google_text"
            android:textSize="15sp"
            android:backgroundTint="@color/surface"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="4dp"
            app:strokeColor="@color/google_border" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_kakao_login"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="카카오로 계속하기"
            android:textColor="@color/kakao_text"
            android:textSize="15sp"
            android:backgroundTint="@color/kakao_yellow"
            app:cornerRadius="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_id_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="아이디로 로그인하기"
            android:textColor="@color/text_secondary"
            style="@style/Widget.MaterialComponents.Button.TextButton" />
    </LinearLayout>

</LinearLayout>
