<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="건강 정보"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="안전한 운동 추천을 위해 필요해요"
            android:textSize="15sp"
            android:textColor="@color/text_secondary" />

        <!-- 운동 목적 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="10dp"
            android:text="운동 목적"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_goal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="false"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_diet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="다이어트"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_muscle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="근육 증가"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_fitness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="체력 향상"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_health"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="건강 유지"
                style="@style/Widget.MaterialComponents.Chip.Choice" />
        </com.google.android.material.chip.ChipGroup>

        <!-- 보유 질환 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="10dp"
            android:text="보유 질환 (복수 선택 가능)"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_disease"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_none"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="해당 없음"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_hypertension"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="고혈압"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_diabetes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="당뇨"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_heart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="심장질환"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_arthritis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="관절염"
                style="@style/Widget.MaterialComponents.Chip.Choice" />
        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>
</ScrollView>
